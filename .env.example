NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
REDIS_URL=redis://localhost:6379
CANONICAL_SERVICE_BASE_URL=http://localhost:4001
# Local application database. Use this for local app runs, ingestion, and local-only development.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/lotus_rfq_service_local
# Separate local test database. Use this for integration tests and schema validation.
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/lotus_rfq_service_test
# Product/supabase database. Use this only for product migrations and explicit Supabase verification.
SUPABASE_DB_URL=postgresql://<supabase-user>:<supabase-password>@<supabase-host>:5432/postgres?sslmode=require
JWT_SECRET=replace-with-long-secret-at-least-32-chars
PREDEXON_BASE_URL=https://api.predexon.com
PREDEXON_API_KEY=
PREDICT_MAINNET_BASE_URL=https://api.predict.fun/
PREDICT_TESTNET_BASE_URL=https://api-testnet.predict.fun/
PREDICT_API_KEY=
PREDICT_METADATA_VERSION=predict-v1
PREDICT_WS_MAINNET_URL=wss://ws.predict.fun/
PREDICT_WS_TESTNET_URL=wss://ws-testnet.predict.fun/
PREDEXON_METADATA_VERSION=predexon-v2
LIMITLESS_BASE_URL=https://api.limitless.exchange
LIMITLESS_API_KEY=
OPINION_OPENAPI_BASE_URL=https://openapi.opinion.trade/openapi
OPINION_API_KEY=
MYRIAD_BASE_URL=https://api-v2.myriadprotocol.com/
MYRIAD_API_KEY=
MYRIAD_METADATA_VERSION=myriad-v1
MYRIAD_EVENT_PAGE_SIZE=100
MYRIAD_MAX_EVENT_PAGES_PER_MARKET=25
MYRIAD_MAX_EVENT_ROWS_PER_MARKET=2500
DEV_SIMULATION_PREVIEW_ENABLED=false
COMBO_RFQ_ENABLED=false
SOR_ENABLED=false
SOR_CANARY_SHADOW_ENABLED=false
SOR_CANARY_PERCENT=0
SOR_CANARY_START_AT=
SOR_CANARY_END_AT=
INTERNAL_CROSS_ENABLED=false
INTERNAL_CROSS_SHADOW_ENABLED=false
INTERNAL_CROSS_SHADOW_PERCENT=0
INTERNAL_CROSS_SHADOW_START_AT=
INTERNAL_CROSS_SHADOW_END_AT=
INTERNAL_NETTING_ENABLED=false
INTERNAL_NETTING_SHADOW_ENABLED=false
INTERNAL_NETTING_SHADOW_PERCENT=0
INTERNAL_NETTING_SHADOW_START_AT=
INTERNAL_NETTING_SHADOW_END_AT=
INTERNAL_NETTING_CANARY_ENABLED=false
INTERNAL_NETTING_CANARY_PERCENT=0
INTERNAL_NETTING_CANARY_START_AT=
INTERNAL_NETTING_CANARY_END_AT=
INTERNAL_CLEARING_ENABLED=false
INTERNAL_CLEARING_SHADOW_ENABLED=false
INTERNAL_CLEARING_SHADOW_PERCENT=0
INTERNAL_CLEARING_SHADOW_START_AT=
INTERNAL_CLEARING_SHADOW_END_AT=
INTERNAL_CLEARING_CANARY_ENABLED=false
INTERNAL_CLEARING_CANARY_PERCENT=0
INTERNAL_CLEARING_CANARY_START_AT=
INTERNAL_CLEARING_CANARY_END_AT=
RESOLUTION_RISK_ENABLED=false
RESOLUTION_RISK_SHADOW_ENABLED=false
RESOLUTION_RISK_SHADOW_PERCENT=0
RESOLUTION_RISK_SHADOW_START_AT=
RESOLUTION_RISK_SHADOW_END_AT=
PHASE3A_GUARDRAIL_SHADOW_ENABLED=false
PHASE3A_GUARDRAIL_SHADOW_PERCENT=0
PHASE3A_GUARDRAIL_SHADOW_START_AT=
PHASE3A_GUARDRAIL_SHADOW_END_AT=
SOR_ACCEPT_AON_AWAIT=true
SOR_ACCEPT_NON_AON_BACKGROUND=true
RELIABILITY_WEIGHT=0.05
LATENCY_WEIGHT=0.03
FAILURE_WEIGHT=0.08
SOR_RESOLUTION_RISK_PENALTY=0.05
